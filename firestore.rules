rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper to check if the user is accessing their own data
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // User Profiles
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    // Tasks
    match /tasks/{taskId} {
      // Allow create if the new document's userId matches the authenticated user
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      
      // Allow read, update, delete if the existing document's userId matches the authenticated user
      allow read, update, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // Weekly Stats
    match /weeklyStats/{statId} {
      // Allow create if the new document's userId matches the authenticated user
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      
      // Allow read, update, delete if the existing document's userId matches the authenticated user
      allow read, update, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }
  }
}
